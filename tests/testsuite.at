AT_INIT("libspacetime")
AT_PACKAGE_NAME("libspacetime")
AT_PACKAGE_BUGREPORT("jpeisach@ubuntu.com")

AT_COLOR_TESTS
AT_SETUP(Earth to Mars conversion (current time))
AT_CHECK([mars_time], [0], [TODO: conversion is off by about one earth second], [])
AT_CLEANUP

AT_SETUP(Mariner 9 entered orbit on MSD 34790)
AT_CHECK([mars_important_dates_mariner9_enter_orbit], [0], [Mariner 9 entered orbit - MSD 34790], [])
AT_CLEANUP


// mkmarstime

AT_SETUP(MSD 0 conversion: Virgo 25 140 at 23:59:56 Airy)
AT_CHECK([mars_mkmarstime_msd0], [0], [MSD 0: 0], [])
AT_CLEANUP

AT_SETUP(Unix timestamp 0 conversion: Kanya 26 191 at 07:05:57 Airy)
AT_CHECK([mars_mkmarstime_unixepoch], [0], [], ["Epoch is not equivalent"])
AT_CLEANUP
