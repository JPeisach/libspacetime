AT_INIT("libspacetime")
AT_PACKAGE_NAME("libspacetime")
AT_PACKAGE_BUGREPORT("jpeisach@ubuntu.com")

AT_COLOR_TESTS

AT_BANNER(mars_time)
AT_SETUP(Earth to Mars conversion (current time))
AT_CHECK([mars_time], [0], [TODO: conversion is off by about one earth second], [])
AT_CLEANUP

AT_SETUP(Mariner 9 entered orbit on MSD 34790)
AT_CHECK([mars_important_dates_mariner9_enter_orbit], [0], [Mariner 9 entered orbit - MSD 34790], [])
AT_CLEANUP

AT_SETUP(Perseverance landed on MSD 52304)
AT_CHECK([mars_important_dates_perseverance_landing], [0], [Perseverance landed - MSD 52304], [])
AT_CLEANUP


AT_BANNER(mkmarstime)
AT_SETUP(MSD 0 conversion: Virgo 25 140 at 23:59:56 Airy)
AT_CHECK([mars_mkmarstime_msd0], [0], [MSD 0: 0], [])
AT_CLEANUP

AT_SETUP(Unix timestamp 0 conversion: Kanya 26 191 at 07:05:57 Airy)
AT_CHECK([mars_mkmarstime_unixepoch], [0], [Epoch: 0], [])
AT_CLEANUP

AT_SETUP(Y2K conversion: Virgo 22 207 at 03:12:30 Airy)
AT_CHECK([mars_mkmarstime_y2k], [0], [Y2K: 946684800], [])
AT_CLEANUP

AT_SETUP(2004 Gregorian Leap Day from Vrishika 24 209 at 11:09:27 Airy)
AT_CHECK([mars_mkmarstime_gregorian_leap_day_2004], [0], [leap_day: 1078012800], [])
AT_CLEANUP

AT_SETUP(Pre-Y2038 conversion: Sagittarius 8 228 at 09:56:08 Airy)
AT_CHECK([mars_mkmarstime_y2038_pre], [0], [Pre Y2038: 2147483646], [])
AT_CLEANUP

AT_SETUP(Y2038 conversion: Sagittarius 8 228 at 09:56:09 Airy)
AT_CHECK([mars_mkmarstime_y2038], [0], [Y2038: 2147483647], [])
AT_CLEANUP

AT_SETUP(Post-Y2038 conversion: Sagittarius 8 228 at 09:56:09 Airy)
AT_CHECK([mars_mkmarstime_y2038_post], [0], [Post Y2038: 2147483648], [])
AT_CLEANUP

AT_SETUP(Darian leap day conversion: Vrishika 28 210 at 09:00:00 Airy)
AT_CHECK([mars_mkmarstime_darian_leap_day_y210], [0], [darian_leap_day on Earth: 1137750559], [])
AT_CLEANUP

AT_BANNER(diffmarstime)
AT_SETUP(Length of one sol: 86400 seconds)
AT_CHECK([mars_diffmarstime_onesol], [0], [Length of one sol: 86400.000000], [])
AT_CLEANUP

AT_BANNER(strfmarstime)

AT_SETUP(%a: abbreviated weeksol name)
AT_CHECK([mars_strfmarstime_solnames_abbreviated], [0], [So Lu Ma Me Jo Ve Sa ], [])
AT_CLEANUP

AT_SETUP(%A: Weeksol name)
AT_CHECK([mars_strfmarstime_solnames], [0], [Solis Lunae Martis Mercurii Jovis Veneris Saturni ], [])
AT_CLEANUP


AT_SETUP(%b: abbreviated month name)
AT_CHECK([mars_strfmarstime_monthnames_abbreviated], [0], [Sag Dha Cap Mak Aqu Kum Pis Min Ari Mes Tau Ris Gem Mit Can Kar Leo Sim Vir Kan Lib Tul Sco Vri ], [])
AT_CLEANUP

AT_SETUP(%B: Month name)
AT_CHECK([mars_strfmarstime_monthnames], [0], [Sagittarius Dhanus Capricornus Makara Aquarius Kumbha Pisces Mina Aries Mesha Taurus Rishabha Gemini Mithuna Cancer Karka Leo Simha Virgo Kanya Libra Tula Scorpius Vrishika ], [])
AT_CLEANUP



AT_SETUP(%c: date and time formatted according to locale: Day-Month-Year style)
AT_SKIP_IF([if locale -a | grep -Fxq "fr_FR.utf8"; then exit 77; fi]) # TODO: Find a better way to filter these, and make it so the matching one can be set as an env variable
AT_CHECK_UNQUOTED([LC_ALL="fr_FR.utf8" mars_strfmarstime_locale_d_t_fmt], [0], [Me 04 Mak 205 09:06:07], [])
AT_CLEANUP

AT_SETUP(%c: date and time formatted according to locale: Year-Month-Day style)
AT_SKIP_IF([if locale -a | grep -Fxq "hu_HU.utf8"; then exit 77; fi]) # TODO: Find a better way to filter these, and make it so the matching one can be set as an env variable. Oh, it turns out there are many different versions of this format. Great.
AT_CHECK_UNQUOTED([LC_ALL="hu_HU.utf8" mars_strfmarstime_locale_d_t_fmt], [0], [205. Mak. 4., Mercurii, 09:06:07 MTC], [])
AT_CLEANUP

# I say "Freedom format" in a satirical way
# TODO: Failing until week number specifier is fixed and I can find the proper value.
AT_SETUP(%c: date and time formatted according to locale: Freedom format style)
AT_SKIP_IF([if locale -a | grep -Fxq "en_US.utf8"; then exit 77; fi]) # TODO: Find a better way to filter these, and make it so the matching one can be set as an env variable. Or don't because it's really just America.
AT_CHECK_UNQUOTED([LC_ALL="en_US.utf8" mars_strfmarstime_locale_d_t_fmt], [0], [], [])
AT_CLEANUP



AT_SETUP(%C: century: year 0)
AT_CHECK([mars_strfmarstime_century_y0], [0], [00], [])
AT_CLEANUP

AT_SETUP(%C: century: year 100)
AT_CHECK([mars_strfmarstime_century_y100], [0], [01], [])
AT_CLEANUP

AT_SETUP(%C: century: year 1000)
AT_CHECK([mars_strfmarstime_century_y1000], [0], [10], [])
AT_CLEANUP

AT_SETUP(%d: sol of month)
AT_CHECK([mars_strfmarstime_sol_of_month], [0], [03 20], [])
AT_CLEANUP

AT_SETUP(%e: sol of month (no leading zero))
AT_CHECK([mars_strfmarstime_sol_of_month_spacelz], [0], [ 3 20], [])
AT_CLEANUP

AT_SETUP(%H: 24-Hour formatting)
AT_CHECK([mars_strfmarstime_24hours], [0], [02 14], [])
AT_CLEANUP

AT_SETUP(%I: 12-Hour formatting)
AT_CHECK([mars_strfmarstime_12hours], [0], [12 01], [])
AT_CLEANUP

AT_SETUP(%j: Sol of year padding)
AT_CHECK([mars_strfmarstime_sol_of_year_padding], [0], [001 010 100], [])
AT_CLEANUP

AT_SETUP(%m: Month padding)
AT_CHECK([mars_strfmarstime_month_padding], [0], [01 10], [])
AT_CLEANUP



AT_SETUP(%p: AM/PM formatting according to locale: All caps version)
AT_SKIP_IF([if locale -a | grep -Fxq "en_US.utf8"; then exit 77; fi]) # TODO: Find a better way to filter these, and make it so the matching one can be set as an env variable.
AT_CHECK_UNQUOTED([LC_ALL="en_US.utf8" mars_strfmarstime_locale_am_pm], [0], [AM PM], [])
AT_CLEANUP

AT_SETUP(%p: AM/PM formatting according to locale: All lowercase version)
AT_SKIP_IF([if locale -a | grep -Fxq "en_GB.utf8"; then exit 77; fi]) # TODO: Find a better way to filter these, and make it so the matching one can be set as an env variable.
AT_CHECK_UNQUOTED([LC_ALL="en_GB.utf8" mars_strfmarstime_locale_am_pm], [0], [am pm], [])
AT_CLEANUP

AT_SETUP(%p: AM/PM formatting according to locale: Punctuated version)
AT_SKIP_IF([if locale -a | grep -Fxq "es_ES.utf8"; then exit 77; fi]) # TODO: Find a better way to filter these, and make it so the matching one can be set as an env variable.
AT_CHECK_UNQUOTED([LC_ALL="es_ES.utf8" mars_strfmarstime_locale_am_pm], [0], [a. m. p. m.], []) # FIXME: What's with this weird space character?
AT_CLEANUP

AT_SETUP(%p: AM/PM formatting according to locale: None)
AT_SKIP_IF([if locale -a | grep -Fxq "hu_HU.utf8"; then exit 77; fi]) # TODO: Find a better way to filter these, and make it so the matching one can be set as an env variable.
AT_CHECK_UNQUOTED([LC_ALL="hu_HU.utf8" mars_strfmarstime_locale_am_pm], [0], [ ], [])
AT_CLEANUP



AT_SETUP(%r: Time formatting according to locale: 12-hr)
AT_SKIP_IF([if locale -a | grep -Fxq "en_US.utf8"; then exit 77; fi]) # TODO: Find a better way to filter these, and make it so the matching one can be set as an env variable.
AT_CHECK_UNQUOTED([LC_ALL="en_US.utf8" mars_strfmarstime_locale_ampm_fmt], [0], [12:00:00 AM 12:00:00 PM], [])
AT_CLEANUP

AT_SETUP(%r: Time formatting according to locale: 24-hr)
AT_SKIP_IF([if locale -a | grep -Fxq "hu_HU.utf8"; then exit 77; fi]) # TODO: Find a better way to filter these, and make it so the matching one can be set as an env variable.
AT_CHECK_UNQUOTED([LC_ALL="hu_HU.utf8" mars_strfmarstime_locale_ampm_fmt], [0], [00:00:00 12:00:00], [])
AT_CLEANUP


AT_SETUP(%S: Seconds padding)
AT_CHECK([mars_strfmarstime_seconds_padding], [0], [00 10], [])
AT_CLEANUP

# If %H, %M, %S are correct, %T will be correct.

AT_SETUP(%n: Newline character)
AT_CHECK([mars_strfmarstime_newline], [0], [
], [])
AT_CLEANUP

AT_SETUP(%t: Tab character)
AT_CHECK([mars_strfmarstime_tab], [0], [	], [])
AT_CLEANUP
